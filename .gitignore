# Unity 项目生成的缓存和临时文件
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# 内存捕获文件，可能会很大且包含敏感数据
/[Mm]emoryCaptures/

# 录制文件，可能会很大
/[Rr]ecordings/

# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio 和 Rider 缓存目录
.vs/
.gradle/

# 自动生成的解决方案和项目文件
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D 生成的 meta 文件
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity 崩溃报告生成的文件
sysinfo.txt

# Crashlytics 生成的文件
crashlytics-build.properties

# 忽略打包后的 Addressables 文件
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# 临时生成的 Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# IDE files
.idea/
*.sln.iml

# Build artifacts and exported packages
*.apk
*.aab
*.unitypackage
*.app

# Asset Store tools
AssetStoreTools*
/Packages/com.unity.asset-store-tools/

# Local project notes
/Docs/

# ML-Agents
ml-training/.venv/
ml-training/results/
ml-training/balance-logs/
Assets/ML-Models/*.onnx

# Claude Code local state
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Unity crash / recovery noise
mono_crash.*
/[Aa]ssets/_Recovery/
/[Aa]ssets/_Recovery.meta

# ML-Agents timer auto-output
/[Aa]ssets/ML-Agents/Timers/*.json

# Local research / scratch notes
/ref/
