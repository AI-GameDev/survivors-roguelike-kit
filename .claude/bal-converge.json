    "knobs": {
      "enemy_damage":          { "ko": "적 공격력",        "desc": "Enemy SO의 Attack 스탯 — 적이 한 번 때릴 때 입히는 데미지" },
      "enemy_hp":              { "ko": "적 체력",          "desc": "Enemy SO의 HP 스탯 — 적의 최대 체력" },
