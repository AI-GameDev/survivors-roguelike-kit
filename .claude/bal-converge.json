      "EXP":      { "ko": "평균 최종 경험치", "desc": "사망 시점의 누적 경험치 평균" },
      "Dist":     { "ko": "평균 적과의 거리", "desc": "사망 시점에 가장 가까운 적과의 거리 평균" }
