{
  "schema_version": 1,
  "diagnostics": {
    "killer_concentration_threshold": 0.6,
    "duration_stddev_ratio_max": 0.15,
    "level_cap_floor": 7,
    "min_dps": 0.25,
    "burst_damage_multiplier": 3.0,
    "damage_variance_max": 0.5,
    "min_runs_for_analysis": 3,
    "bimodal_sigma_ratio_min": 0.4,
    "bimodal_requires_timeout": true,
    "overcrowd_count_min": 80
  },
  "knobs": [
    {
      "id": "enemy_damage",
      "label": "Enemy damage tuning",
      "triggers": ["killer_concentration", "burst_damage_at_death"],
      "asset_glob": "Assets/RGame/RoguelikeKit/ScriptableObjects/DataSO/Enemy/**/*.asset",
      "asset_match": {
        "type": "value_config_named",
        "name_mode": "filename",
        "name_match_log_key": "episode.last_hit_attacker"
      },
      "field_path": "ValueDefinitions[ValueName=Attack].DefaultValue",
      "adjust_default": -0.15,
      "adjust_range": [-0.5, 0.5]
    },
    {
      "id": "enemy_hp",
      "label": "Enemy HP tuning",
      "triggers": ["low_kill_rate"],
      "asset_glob": "Assets/RGame/RoguelikeKit/ScriptableObjects/DataSO/Enemy/**/*.asset",
      "asset_match": {
        "type": "value_config_named",
        "name_mode": "filename"
      },
      "field_path": "ValueDefinitions[ValueName=HP].DefaultValue",
      "adjust_default": -0.1,
      "adjust_range": [-0.5, 0.5]
    },
    {
      "id": "spawn_rate",
      "label": "Spawn base rate",
      "triggers": ["spawn_cliff"],
      "asset_glob": "Assets/RGame/RoguelikeKit/ScriptableObjects/DataSO/Level/Stages/StageSet/**/*.asset",
      "asset_match": {
        "type": "value_config_named",
        "name_mode": "filename_prefix",
        "name_match_log_key": "event.enemy_spawn.set_key",
        "name_match_window": {
          "anchor": "episode.cause",
          "before_sec": 5,
          "agg": "mode",
          "min_events": 5
        }
      },
      "field_path": "BaseRatePerSecond",
      "adjust_default": -0.2,
      "adjust_range": [-0.5, 0.5],
      "note": "SpawnSet.cs: BaseRatePerSecond is Pattern==Random only. For Dense/Circle use spawn_burst_count."
    },
    {
      "id": "spawn_burst_count",
      "label": "Burst spawn count (Dense/Circle)",
      "triggers": ["structural_duration_cutoff"],
      "asset_glob": "Assets/RGame/RoguelikeKit/ScriptableObjects/DataSO/Level/Stages/StageSet/**/*.asset",
      "asset_match": {
        "type": "value_config_named",
        "name_mode": "filename_prefix",
        "name_match_log_key": "event.enemy_spawn.set_key",
        "name_match_window": {
          "anchor": "episode.cause",
          "before_sec": 5,
          "agg": "mode",
          "min_events": 5
        }
      },
      "field_path": "Count",
      "adjust_default": -0.25,
      "adjust_range": [-0.7, 0.5],
      "note": "SpawnSet.cs: Count is the burst size for Pattern==Dense/Circle (ignored for Random). Integer field — large base values (e.g. 30) round-trip cleanly."
    },
    {
      "id": "spawn_intensity_curve",
      "label": "Spawn intensity curve (manual)",
      "triggers": ["spawn_cliff", "structural_duration_cutoff"],
      "asset_glob": "Assets/RGame/RoguelikeKit/ScriptableObjects/DataSO/Level/Stages/StageSet/**/*.asset",
      "field_path": "IntensityCurve",
      "action": "open_in_unity",
      "note": "AnimationCurve는 Unity Editor에서 직접 시각 편집 권장. 자동 적용 안 함."
    },
    {
      "id": "level_up_xp_increment",
      "label": "Level-up XP increment",
      "triggers": ["level_cap_low"],
      "asset_glob": "Assets/RGame/RoguelikeKit/ScriptableObjects/DataSO/Exp/ExpConfig.asset",
      "field_path": "experienceIncrement",
      "adjust_default": -0.2,
      "adjust_range": [-0.5, 0.5],
      "note": "ExpConfig.GetExperienceForLevel = baseExperience + (level-1) * experienceIncrement. Reducing the increment lowers the per-level XP cost growth, helping players reach higher levels in the same playtime."
    },
    {
      "id": "player_max_hp",
      "label": "Player max HP",
      "triggers": ["high_damage_taken_variance", "rapid_death"],
      "asset_glob": "Assets/RGame/RoguelikeKit/ScriptableObjects/DataSO/Player/PlayerStat.asset",
      "asset_match": {
        "type": "value_config_named",
        "note": "PlayerRuntimeStat is the runtime mutable copy and should not be edited; glob narrowed to the design-time PlayerStat asset only."
      },
      "field_path": "ValueDefinitions[ValueName=HP].DefaultValue",
      "adjust_default": 0.1,
      "adjust_range": [-0.3, 0.5]
    },
    {
      "id": "early_spawn_rate",
      "label": "Early-window spawn rate ease (0~90s)",
      "triggers": ["bimodal_early_part"],
      "asset_glob": "Assets/RGame/RoguelikeKit/ScriptableObjects/DataSO/Level/Stages/StageSet/**/*.asset",
      "asset_match": {
        "type": "value_config_named",
        "name_mode": "filename_list",
        "names": ["Gear"]
      },
      "field_path": "BaseRatePerSecond",
      "adjust_default": -0.5,
      "adjust_range": [-0.7, 0.0],
      "note": "Early-window (0~90s) Random pattern SpawnSet base rate down. names 는 StartTime<90s 인 Random 자산 stem. 2026-05-23 03:30: Gear 1 제거 — 실제 StartTime=360 (late) 였음. 추가 early 후보 (Slime/Bat/Bat 1/FlySkull) 는 별건."
    },
    {
      "id": "late_spawn_burst_amplify",
      "label": "Late-window burst Count amplify (180~270s)",
      "triggers": ["bimodal_late_burst"],
      "asset_glob": "Assets/RGame/RoguelikeKit/ScriptableObjects/DataSO/Level/Stages/StageSet/**/*.asset",
      "asset_match": {
        "type": "value_config_named",
        "name_mode": "filename_list",
        "names": ["Ghost 3", "Ghost 4", "Ghost 5", "Ghost 6", "BoyFairy1", "BoyFairy2"]
      },
      "field_path": "Count",
      "adjust_default": 1.0,
      "adjust_range": [0.0, 4.0],
      "note": "Late-window (180~270s) Dense/Circle burst Count 2x. Integer 필드 — 큰 베이스 (15, 20) 라 round-trip 안정. 2026-05-23 03:30: 3x→2x 로 완화 (모델이 Count=15 에 학습 → +200% 는 OOD, +100% 는 학습 환경 Count=30 직전 부근)."
    },
    {
      "id": "late_spawn_rate_amplify",
      "label": "Late-window sustained rate amplify (180~360s)",
      "triggers": ["bimodal_late_rate"],
      "asset_glob": "Assets/RGame/RoguelikeKit/ScriptableObjects/DataSO/Level/Stages/StageSet/**/*.asset",
      "asset_match": {
        "type": "value_config_named",
        "name_mode": "filename_list",
        "names": ["ForestGuardianFairy"]
      },
      "field_path": "BaseRatePerSecond",
      "adjust_default": 2.0,
      "adjust_range": [0.0, 10.0],
      "note": "Late-window long-sustained Random pressure 3x (0.3 → 0.9). bimodal 깨기용 지속 압력. 2026-05-23 03:30: 6x→3x 완화 (6x 는 over-OOD, 3x 도 충분히 지속 압력)."
    }
  ]
}
